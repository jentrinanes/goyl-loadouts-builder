{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "_api_dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "_api_dist"]
}
